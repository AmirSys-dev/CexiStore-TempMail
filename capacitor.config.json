{
  "appId": "com.cexistore.app",
  "appName": "Cexistore",
  "webDir": "../dist",
  "server": {
    "url": "https://tempmail.amircexitech.com",
    "cleartext": true,
    "allowNavigation": [
      "*.supabase.co",
      "*.github.com",
      "*.google.com",
      "*.googleapis.com",
      "accounts.google.com",
      "github.com",
      "tempmail.amircexitech.com"
    ]
  },
  "android": {
    "backgroundColor": "#000000",
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#000000",
      "showSpinner": false
    }
  }
}
